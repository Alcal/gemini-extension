# Backend URLs (injected by docker-compose.yml in production)
RAG_URL=http://rag-server:8000
DATABASE_URL=postgresql://hardware:hardware@sql-database:5432/hardware

# Google Gemini API key — required by the ask_assistant tool (geminiService.js).
# Get one at https://aistudio.google.com/apikey. Never commit the real value.
GEMINI_API_KEY=
