{
  "name": "gemini-mcp-hardware-extension",
  "version": "1.0.0",
  "description": "Access automation hardware specifications and stock levels.",
  "mcpServers": {
    "hardware-mcp": {
      "command": "docker",
      "args": [
        "compose",
        "-f",
        "${extensionPath}${/}docker-compose.yml",
        "run",
        "--rm",
        "-i",
        "mcp-server"
      ],
      "cwd": "${extensionPath}"
    }
  },
  "contextFileName": "GEMINI.md"
}
